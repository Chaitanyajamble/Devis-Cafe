# ---------------- Menu <-> Inventory recipe linking ----------------

def link_ingredient(db: Session, payload: MenuItemIngredientCreate) -> MenuItemIngredient:
    get_inventory_item(db, payload.inventory_item_id)
    link = MenuItemIngredient(**payload.model_dump())
    db.add(link)
    db.commit()
    db.refresh(link)
    return link


def deduct_inventory_for_order(db: Session, order_items: list):
    """
    Business Rule: Inventory updates automatically after order completion.
    Deducts stock based on menu item recipes (MenuItemIngredient) for each order item.
    """
    for order_item in order_items:
        links = db.query(MenuItemIngredient).filter(
            MenuItemIngredient.menu_item_id == order_item.menu_item_id
        ).all()
        for link in links:
            inv_item = db.get(InventoryItem, link.inventory_item_id)
            if inv_item:
                required = float(link.quantity_required) * order_item.quantity
                inv_item.quantity_in_stock = max(0.0, float(inv_item.quantity_in_stock) - required)
    # caller commits as part of the larger transaction


def validate_stock_availability(db: Session, menu_item_id: str, quantity: int) -> bool:
    """Checks if enough inventory exists to prepare `quantity` of a menu item."""
    links = db.query(MenuItemIngredient).filter(MenuItemIngredient.menu_item_id == menu_item_id).all()
    for link in links:
        inv_item = db.get(InventoryItem, link.inventory_item_id)
        if not inv_item:
            continue
        required = float(link.quantity_required) * quantity
        if float(inv_item.quantity_in_stock) < required:
            return False
    return True
