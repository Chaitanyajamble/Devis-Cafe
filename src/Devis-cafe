# Allowed forward transitions for order status (prevents invalid jumps, e.g. Pending -> Completed)
VALID_TRANSITIONS = {
    OrderStatus.PENDING: {OrderStatus.CONFIRMED, OrderStatus.CANCELLED},
    OrderStatus.CONFIRMED: {OrderStatus.PREPARING, OrderStatus.CANCELLED},
    OrderStatus.PREPARING: {OrderStatus.READY, OrderStatus.CANCELLED},
    OrderStatus.READY: {OrderStatus.COMPLETED, OrderStatus.CANCELLED},
    OrderStatus.COMPLETED: set(),
    OrderStatus.CANCELLED: set(),
}


def _calc_totals(order: Order, tax_percent: float = 5.0, discount_amount: float = 0.0):
    subtotal = sum(float(i.line_total) for i in order.items)
    tax_amount = round(subtotal * (tax_percent / 100), 2)
    order.subtotal = subtotal
    order.tax_amount = tax_amount
    order.discount_amount = discount_amount
    order.total_amount = round(subtotal + tax_amount - discount_amount, 2)


def create_order(db: Session, payload: OrderCreate, current_user) -> Order:
    if payload.order_type == OrderType.DINE_IN and not payload.table_id:
        raise ValidationException("table_id is required for dine-in orders")
    if payload.order_type == OrderType.DELIVERY and not payload.delivery_address:
        raise ValidationException("delivery_address is required for delivery orders")

    order = Order(
        order_number=generate_order_number(),
        customer_id=payload.customer_id,
        table_id=payload.table_id,
        created_by=current_user.id,
        order_type=payload.order_type,
        delivery_address=payload.delivery_address,
        notes=payload.notes,
        status=OrderStatus.PENDING,
    )
    db.add(order)
    db.flush()

    for line in payload.items:
        menu_item = db.get(MenuItem, line.menu_item_id)
        if not menu_item or menu_item.is_deleted:
            raise NotFoundException(f"Menu item {line.menu_item_id} not found")
        if not menu_item.is_available:
            raise ValidationException(f"Menu item '{menu_item.name}' is currently unavailable")
        if not inventory_service.validate_stock_availability(db, menu_item.id, line.quantity):
            raise ValidationException(f"Insufficient stock to prepare '{menu_item.name}'")

        order_item = OrderItem(
            order_id=order.id,
            menu_item_id=menu_item.id,
            quantity=line.quantity,
            unit_price=menu_item.price,
            line_total=float(menu_item.price) * line.quantity,
            special_instructions=line.special_instructions,
        )
        db.add(order_item)

    db.flush()
    db.refresh(order)
    _calc_totals(order)

    if order.order_type == OrderType.DINE_IN and order.table_id:
        table = db.get(CafeTable, order.table_id)
        if table:
            table.status = TableStatus.OCCUPIED

    db.commit()
    db.refresh(order)
    return order


def get_order(db: Session, order_id: str) -> Order:
    order = db.get(Order, order_id)
    if not order:
        raise NotFoundException("Order not found")
    return order


def list_orders(db: Session, status: OrderStatus | None = None, order_type: OrderType | None = None, page: int = 1, page_size: int = 20):
    query = db.query(Order)
    if status:
        query = query.filter(Order.status == status)
    if order_type:
        query = query.filter(Order.order_type == order_type)
    total = query.count()
    items = query.order_by(Order.created_at.desc()).offset((page - 1) * page_size).limit(page_size).all()
    return items, total


def modify_order_items(db: Session, order_id: str, payload: OrderItemUpdate) -> Order:
    order = get_order(db, order_id)
    if order.status not in (OrderStatus.PENDING, OrderStatus.CONFIRMED):
        raise ConflictException("Order can only be modified while Pending or Confirmed")

    # remove old items, replace with new set
    for old_item in list(order.items):
        db.delete(old_item)
    db.flush()

    for line in payload.items:
        menu_item = db.get(MenuItem, line.menu_item_id)
        if not menu_item or menu_item.is_deleted:
            raise NotFoundException(f"Menu item {line.menu_item_id} not found")
        if not inventory_service.validate_stock_availability(db, menu_item.id, line.quantity):
            raise ValidationException(f"Insufficient stock to prepare '{menu_item.name}'")
        order_item = OrderItem(
            order_id=order.id,
            menu_item_id=menu_item.id,
            quantity=line.quantity,
            unit_price=menu_item.price,
            line_total=float(menu_item.price) * line.quantity,
            special_instructions=line.special_instructions,
        )
        db.add(order_item)

    db.flush()
    db.refresh(order)
    _calc_totals(order)
    db.commit()
    db.refresh(order)
    return order


def update_order_status(db: Session, order_id: str, payload: OrderStatusUpdate, current_user) -> Order:
    """Business Rule: Orders must be confirmed before preparation."""
    order = get_order(db, order_id)
    allowed_next = VALID_TRANSITIONS.get(order.status, set())
    if payload.status not in allowed_next:
        raise ConflictException(f"Cannot transition order from {order.status} to {payload.status}")

    order.status = payload.status

    if payload.status == OrderStatus.COMPLETED:
        # Inventory updates automatically after order completion.
        inventory_service.deduct_inventory_for_order(db, order.items)
        if order.table_id:
            table = db.get(CafeTable, order.table_id)
            if table:
                table.status = TableStatus.CLEANING

    if payload.status == OrderStatus.CANCELLED and order.table_id:
        table = db.get(CafeTable, order.table_id)
        if table and table.status == TableStatus.OCCUPIED:
            table.status = TableStatus.AVAILABLE

    write_audit_log(db, current_user.id, "ORDER_STATUS_CHANGED", "Order", order.id, f"new_status={payload.status}")
    db.commit()
    db.refresh(order)
    return order


def cancel_order(db: Session, order_id: str, current_user) -> Order:
    return update_order_status(db, order_id, OrderStatusUpdate(status=OrderStatus.CANCELLED), current_user)
