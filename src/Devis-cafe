from app.schemas.billing import BillPreviewRequest, PaymentCreate
from app.core.exceptions import NotFoundException, ValidationException, ConflictException
from app.services import order_service, customer_service, inventory_service
from app.utils.audit import write_audit_log

LOYALTY_POINTS_PER_100 = 5  # 5 points earned per 100 currency units spent


def preview_bill(db: Session, payload: BillPreviewRequest) -> Order:
    order = order_service.get_order(db, payload.order_id)
    subtotal = float(order.subtotal)
    tax_amount = round(subtotal * (payload.tax_percent / 100), 2)
    order.tax_amount = tax_amount
    order.discount_amount = payload.discount_amount
    order.total_amount = round(subtotal + tax_amount - payload.discount_amount, 2)
    db.commit()
    db.refresh(order)
    return order


def process_payment(db: Session, payload: PaymentCreate, current_user) -> Payment:
    order = order_service.get_order(db, payload.order_id)

    if order.status == OrderStatus.CANCELLED:
        raise ConflictException("Cannot pay for a cancelled order")
    if order.payment and order.payment.status == PaymentStatus.SUCCESS:
        raise ConflictException("Order is already paid")

    if round(float(payload.amount), 2) != round(float(order.total_amount), 2):
        raise ValidationException(
            f"Payment amount ({payload.amount}) does not match order total ({order.total_amount})"
        )

    payment = order.payment
    if payment:
        payment.amount = payload.amount
        payment.method = payload.method
        payment.transaction_ref = payload.transaction_ref
        payment.status = PaymentStatus.SUCCESS
    else:
        payment = Payment(
            order_id=order.id,
            amount=payload.amount,
            method=payload.method,
            transaction_ref=payload.transaction_ref,
            status=PaymentStatus.SUCCESS,
        )
        db.add(payment)

    # Business Rule: Payment success triggers loyalty points and order completion.
    if order.status in (OrderStatus.READY, OrderStatus.PREPARING, OrderStatus.CONFIRMED, OrderStatus.PENDING):
        order.status = OrderStatus.COMPLETED
        inventory_service.deduct_inventory_for_order(db, order.items)

    if order.customer_id:
        points = int(float(order.total_amount) // 100) * LOYALTY_POINTS_PER_100
        if points > 0:
            customer_service.award_loyalty_points(db, order.customer_id, points, order.id)

    write_audit_log(db, current_user.id, "PAYMENT_PROCESSED", "Payment", payment.id, f"amount={payload.amount}")
    db.commit()
    db.refresh(payment)
    return payment


def get_payment(db: Session, order_id: str) -> Payment:
    order = order_service.get_order(db, order_id)
    if not order.payment:
        raise NotFoundException("No payment found for this order")
    return order.payment


def refund_payment(db: Session, order_id: str, current_user) -> Payment:
    payment = get_payment(db, order_id)
    if payment.status != PaymentStatus.SUCCESS:
        raise ConflictException("Only successful payments can be refunded")
    payment.status = PaymentStatus.REFUNDED
    write_audit_log(db, current_user.id, "PAYMENT_REFUNDED", "Payment", payment.id)
    db.commit()
    db.refresh(payment)
    return payment
