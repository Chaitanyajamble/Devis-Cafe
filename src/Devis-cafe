def create_inventory_item(db: Session, payload: InventoryItemCreate) -> InventoryItem:
    if payload.supplier_id:
        get_supplier(db, payload.supplier_id)
    item = InventoryItem(**payload.model_dump())
    db.add(item)
    db.commit()
    db.refresh(item)
    return item


def list_inventory_items(db: Session, low_stock_only: bool = False):
    items = db.query(InventoryItem).order_by(InventoryItem.name).all()
    if low_stock_only:
        items = [i for i in items if i.quantity_in_stock <= i.reorder_level]
    return items


