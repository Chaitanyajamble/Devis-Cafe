from app.models.customer import Customer, CustomerLoyaltyTransaction, LoyaltyTxnType
from app.schemas.customer import CustomerCreate, CustomerUpdate
from app.core.exceptions import ValidationException, NotFoundException


def create_customer(db: Session, payload: CustomerCreate) -> Customer:
    existing = db.query(Customer).filter(
        or_(Customer.mobile == payload.mobile, Customer.email == payload.email if payload.email else False)
    ).first()
    if existing:
        raise ValidationException("Customer with this mobile or email already exists")

    customer = Customer(full_name=payload.full_name, email=payload.email, mobile=payload.mobile)
    db.add(customer)
    db.commit()
    db.refresh(customer)
    return customer


def get_customer(db: Session, customer_id: str) -> Customer:
    customer = db.get(Customer, customer_id)
    if not customer:
        raise NotFoundException("Customer not found")
    return customer


def list_customers(db: Session, page: int, page_size: int, search: str | None = None):
    query = db.query(Customer)
    if search:
        like = f"%{search}%"
        query = query.filter(or_(Customer.full_name.ilike(like), Customer.mobile.ilike(like), Customer.email.ilike(like)))
    total = query.count()
    items = query.order_by(Customer.created_at.desc()).offset((page - 1) * page_size).limit(page_size).all()
    return items, total


def update_customer(db: Session, customer_id: str, payload: CustomerUpdate) -> Customer:
    customer = get_customer(db, customer_id)
    update_data = payload.model_dump(exclude_unset=True)
    for field, value in update_data.items():
        setattr(customer, field, value)
    db.commit()
    db.refresh(customer)
    return customer


def get_order_history(db: Session, customer_id: str):
    customer = get_customer(db, customer_id)
    return customer.orders


def award_loyalty_points(db: Session, customer_id: str, points: int, order_id: str):
    """Business Rule: Loyalty points awarded only after successful payment."""
    customer = get_customer(db, customer_id)
    customer.loyalty_points += points
    txn = CustomerLoyaltyTransaction(
        customer_id=customer_id,
        points=points,
        txn_type=LoyaltyTxnType.EARNED,
        reference_order_id=order_id,
        note="Earned from order payment",
    )
    db.add(txn)
    # caller is responsible for commit (keeps payment + loyalty atomic)


def redeem_loyalty_points(db: Session, customer_id: str, points: int) -> Customer:
    customer = get_customer(db, customer_id)
    if customer.loyalty_points < points:
        raise ValidationException("Insufficient loyalty points")
    customer.loyalty_points -= points
    txn = CustomerLoyaltyTransaction(
        customer_id=customer_id, points=points, txn_type=LoyaltyTxnType.REDEEMED, note="Redeemed by customer"
    )
    db.add(txn)
    db.commit()
    db.refresh(customer)
    return customer
