# ---------------- Categories ----------------

def create_category(db: Session, payload: MenuCategoryCreate) -> MenuCategory:
    existing = db.query(MenuCategory).filter(MenuCategory.name == payload.name, MenuCategory.is_deleted == False).first()
    if existing:
        raise ValidationException("Category with this name already exists")
    category = MenuCategory(name=payload.name, description=payload.description)
    db.add(category)
    db.commit()
    db.refresh(category)
    return category


def list_categories(db: Session):
    return db.query(MenuCategory).filter(MenuCategory.is_deleted == False).order_by(MenuCategory.name).all()


def get_category(db: Session, category_id: str) -> MenuCategory:
    category = db.query(MenuCategory).filter(MenuCategory.id == category_id, MenuCategory.is_deleted == False).first()
    if not category:
        raise NotFoundException("Menu category not found")
    return category


def update_category(db: Session, category_id: str, payload: MenuCategoryUpdate) -> MenuCategory:
    category = get_category(db, category_id)
    for field, value in payload.model_dump(exclude_unset=True).items():
        setattr(category, field, value)
    db.commit()
    db.refresh(category)
    return category


def delete_category(db: Session, category_id: str):
    category = get_category(db, category_id)
    category.is_deleted = True
    db.commit()


# ---------------- Menu Items ----------------

def create_item(db: Session, payload: MenuItemCreate, current_user: User) -> MenuItem:
    get_category(db, payload.category_id)  # ensures category exists
    item = MenuItem(**payload.model_dump())
    db.add(item)
    db.flush()
    write_audit_log(db, current_user.id, "MENU_ITEM_CREATED", "MenuItem", item.id, f"price={item.price}")
    db.commit()
    db.refresh(item)
    return item


def list_items(db: Session, category_id: str | None = None, only_available: bool = False):
    query = db.query(MenuItem).filter(MenuItem.is_deleted == False)
    if category_id:
        query = query.filter(MenuItem.category_id == category_id)
    if only_available:
        query = query.filter(MenuItem.is_available == True)
    return query.order_by(MenuItem.name).all()


def get_item(db: Session, item_id: str) -> MenuItem:
    item = db.query(MenuItem).filter(MenuItem.id == item_id, MenuItem.is_deleted == False).first()
    if not item:
        raise NotFoundException("Menu item not found")
    return item


def update_item(db: Session, item_id: str, payload: MenuItemUpdate, current_user: User) -> MenuItem:
    """Business Rule: Only Managers and Owners can modify menu prices."""
    item = get_item(db, item_id)
    update_data = payload.model_dump(exclude_unset=True)

    if "price" in update_data and update_data["price"] is not None:
        if current_user.role not in (RoleEnum.OWNER, RoleEnum.MANAGER):
            raise ForbiddenException("Only Managers and Owners can modify menu prices")
        write_audit_log(
            db, current_user.id, "MENU_PRICE_CHANGED", "MenuItem", item.id,
            f"old_price={item.price}, new_price={update_data['price']}"
        )

    for field, value in update_data.items():
        setattr(item, field, value)
    db.commit()
    db.refresh(item)
    return item


